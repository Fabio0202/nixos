do_theme_catppuccin() { ~/.local/bin/theme catppuccin-mocha && notify "Theme: Catppuccin Mocha"; exit 0; }
do_theme_everforest() { ~/.local/bin/theme everforest        && notify "Theme: Everforest";       exit 0; }
do_theme_rose_pine()  { ~/.local/bin/theme rose-pine         && notify "Theme: Rose Pine";        exit 0; }
do_theme_gruvbox()    { ~/.local/bin/theme gruvbox           && notify "Theme: Gruvbox";          exit 0; }
do_theme_kanagawa()   { ~/.local/bin/theme kanagawa          && notify "Theme: Kanagawa";         exit 0; }
do_theme_nord()       { ~/.local/bin/theme nord              && notify "Theme: Nord";             exit 0; }
do_theme_cycle()      { ~/.local/bin/theme && notify "Theme: $(cat ~/.config/.current-theme 2>/dev/null)"; exit 0; }

# Wallpaper
do_wallpaper_change() { waypaper & exit 0; }
do_wallpaper_folder() { nautilus ~/nixos/files/wallpapers & exit 0; }
do_wallpaper_next() {
    local WAYPAPER_CONFIG="$HOME/.config/waypaper/config.ini"
    [[ ! -f "$WAYPAPER_CONFIG" ]] && { notify "Waypaper config not found"; return; }
    local current_folder current_name next_wallpaper
    current_folder=$(grep "^folder" "$WAYPAPER_CONFIG" | cut -d'=' -f2 | xargs)
    current_folder="${current_folder/#\~/$HOME}"
    current_name=$(basename "$(grep "^wallpaper" "$WAYPAPER_CONFIG" | cut -d'=' -f2 | xargs)")
    mapfile -t wallpapers < <(find "$current_folder" -maxdepth 1 -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.jpeg" \) | sort)
    [[ ${#wallpapers[@]} -eq 0 ]] && { notify "No wallpapers found"; return; }
    next_wallpaper="${wallpapers[0]}"
    for i in "${!wallpapers[@]}"; do
        if [[ "$(basename "${wallpapers[$i]}")" == "$current_name" ]]; then
            next_wallpaper="${wallpapers[$(( (i+1) % ${#wallpapers[@]} ))]}"
            break
        fi
    done
    swww img "$next_wallpaper" --transition-type any --transition-duration 1 &
    sed -i "s|^wallpaper = .*|wallpaper = $next_wallpaper|" "$WAYPAPER_CONFIG"
    notify "Wallpaper: $(basename "$next_wallpaper")"
    exit 0
}

# Nix
do_nix_update() {
    [[ ! -f "$HOME/.zsh/aliases.zsh" ]] && { notify "Missing: ~/.zsh/aliases.zsh"; return; }
    kitty --title "Nix: Update" -e zsh -c 'setopt aliases; source ~/.zsh/aliases.zsh; eval update' &
    exit 0
}

