# ─── APP SCANNER ──────────────────────────────────────────────────────────────
# Outputs 3 tab-separated fields: app_id <TAB> name <TAB> icon_name

scan_apps() {
    local desktop_dirs=(
        "/run/current-system/sw/share/applications"
        "/etc/profiles/per-user/$USER/share/applications"
        "$HOME/.nix-profile/share/applications"
        "$HOME/.local/share/applications"
        "/var/lib/flatpak/exports/share/applications"
        "$HOME/.local/share/flatpak/exports/share/applications"
    )
    local existing_dirs=()
    for dir in "${desktop_dirs[@]}"; do
        [[ -d "$dir" ]] && existing_dirs+=("$dir")
    done
    [[ ${#existing_dirs[@]} -eq 0 ]] && return

    find "${existing_dirs[@]}" -maxdepth 1 -name "*.desktop" -print0 2>/dev/null \
    | sort -z \
    | xargs -0 -r awk '
        FNR == 1 {
            if (started && show && name != "") {
                n = split(prev, a, "/"); base = a[n]; sub(/\.desktop$/, "", base)
                print base "\t" name "\t" icon
            }
            started = 1; prev = FILENAME; name = ""; icon = ""; show = 1
        }
        /^Name=/ && name == ""              { name = substr($0, 6) }
        /^Icon=/ && icon == ""              { icon = substr($0, 6) }
        /^NoDisplay=true/ || /^Hidden=true/ { show = 0 }
        END {
            if (show && name != "") {
                n = split(prev, a, "/"); base = a[n]; sub(/\.desktop$/, "", base)
                print base "\t" name "\t" icon
            }
        }
    ' 2>/dev/null \
    | awk -F'\t' '!seen[$2]++'
}

# ─── FLAT MENU ────────────────────────────────────────────────────────────────
# Uses a temp file so entries with null bytes (icons) can be sorted cleanly,
# then outputs null-byte icon data directly to the pipe for rofi to consume.

build_menu() {
    declare -A scores
    if [[ -f "$FRECENCY_FILE" ]]; then
        while IFS=$'\t' read -r id count _rest; do
            scores["$id"]="$count"
        done < "$FRECENCY_FILE"
    fi

    local tmp
    tmp=$(mktemp)

    # System entries: score<TAB>label<TAB>icon
    for i in "${!ENTRY_IDS[@]}"; do
        local score="${scores[${ENTRY_IDS[$i]}]:-0}"
        printf '%010d\t%s\t%s\n' "$score" "${ENTRY_LABELS[$i]}" "${ENTRY_ICONS[$i]}" >> "$tmp"
    done

    # App entries: score<TAB>name<TAB>icon_name
    while IFS=$'\t' read -r app_id app_name icon_name; do
        local score="${scores[app_${app_id}]:-0}"
        printf '%010d\t%s\t%s\n' "$score" "$app_name" "$icon_name" >> "$tmp"
    done < <(scan_apps)

    # Sort by score desc, then output — adding null-byte icon data for apps
    sort -t$'\t' -k1 -rn "$tmp" | while IFS=$'\t' read -r _score label icon; do
        if [[ -n "$icon" ]]; then
            printf '%s\x00icon\x1f%s\n' "$label" "$icon"
        else
            printf '%s\n' "$label"
        fi
    done

    printf '%s\n' "󰒼  Browse all..."
    rm -f "$tmp"
}

flat_menu() {
    register_entries

    local choice
    # Pipe directly — null bytes for icons flow through the pipe to rofi fine
    choice=$(build_menu | rofi $ROFI_OPTS -show-icons -kb-cancel "" -kb-custom-1 "Escape" -p "")
    [[ $? -eq 10 || -z "$choice" ]] && exit 0

    if [[ "$choice" == *"Browse all"* ]]; then
        hier_main_menu
        return
    fi

    # Match system entries first
    for i in "${!ENTRY_LABELS[@]}"; do
        if [[ "${ENTRY_LABELS[$i]}" == "$choice" ]]; then
            frecency_bump "${ENTRY_IDS[$i]}" "$choice"
            "${ENTRY_ACTIONS[$i]}"
            return
        fi
    done

    # Must be an app — look up by name and launch
    while IFS=$'\t' read -r app_id app_name _icon; do
        if [[ "$app_name" == "$choice" ]]; then
            frecency_bump "app_${app_id}" "$app_name"
            gtk-launch "$app_id" &
            return
        fi
    done < <(scan_apps)
}

# ─── HIERARCHICAL MENU (Browse mode) ──────────────────────────────────────────

hier_main_menu() {
    while true; do
        local sunset_entry timer_entry timer_status choice
        pgrep -x hyprsunset > /dev/null && sunset_entry="󱩐  Hyprsunset (ON)" || sunset_entry="󱩐  Hyprsunset (OFF)"
        timer_status=$(timer status 2>/dev/null)
        if   [[ "$timer_status" == "ringing" ]]; then timer_entry="󰂞  Timer (ALARM!)"
        elif [[ "$timer_status" == "running" ]]; then timer_entry="󰄉  Timer ($(timer remaining 2>/dev/null))"
        else timer_entry="󰄉  Timer"
        fi

        choice=$(show_rofi "Browse" \
            "󰒼  Config" \
            "󰆏  Screenshots" \
            "󰣀  SSH" \
            "󰂯  Bluetooth" \
            "󰕾  Audio" \
            "󰗀  Themes" \
            "󰖩  Wifi" \
            "󰸉  Wallpaper" \
            "$timer_entry" \
            "󰏘  Color Picker" \
            "$sunset_entry" \
            "󰎈  Media" \
            "󰒓  System" \
            "󱄅  Nix")
        [[ $? -eq 10 || -z "$choice" ]] && return

        case "$choice" in
            *"System"*)       hier_system_menu ;;
            *"Wifi"*)        hier_wifi_menu ;;
            *"Bluetooth"*)    hier_bt_menu ;;
            *"Audio"*)        hier_audio_menu ;;
            *"Screenshots"*)  hier_screenshots_menu ;;
            *"Media"*)        hier_media_menu ;;
            *"Themes"*)       hier_themes_menu ;;
            *"Wallpaper"*)    hier_wallpaper_menu ;;
            *"Config"*)       hier_config_menu ;;
            *"SSH"*)          do_ssh_connect ;;
            *"Timer"*)        hier_timer_menu ;;
            *"Nix"*)          hier_nix_menu ;;
            *"Color Picker"*) do_color_picker ;;
            *"Hyprsunset"*)   do_hyprsunset_toggle ;;
        esac
    done
}

hier_system_menu() {
    while true; do
        local choice
        choice=$(show_rofi "System" "󰐥  Shutdown" "󰜉  Reboot" "󰤄  Suspend" "󰒳  Lock" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Shutdown"*) do_shutdown ;;
            *"Reboot"*)   do_reboot ;;
            *"Suspend"*)  do_suspend ;;
            *"Lock"*)     do_lock ;;
            *"Back"*|"")  return ;;
        esac
    done
}

hier_wifi_menu() {
    while true; do
        local toggle_entry choice
        nmcli radio wifi | grep -q enabled && toggle_entry="󰤨  Toggle (ON)" || toggle_entry="󰤭  Toggle (OFF)"
        choice=$(show_rofi "Wifi" "󰖩  Connect" "󰖩  Status" "$toggle_entry" "󰖪  Disconnect" "󰌆  Settings" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Connect"*)    do_wifi_connect ;;
            *"Status"*)     do_wifi_status ;;
            *"Toggle"*)     do_wifi_toggle ;;
            *"Disconnect"*) do_wifi_disconnect ;;
            *"Settings"*)   do_wifi_settings; return ;;
            *"Back"*|"")    return ;;
        esac
    done
}

hier_bt_menu() {
    while true; do
        local toggle_entry choice
        bluetoothctl show | grep -q "Powered: yes" && toggle_entry="󰂯  Toggle (ON)" || toggle_entry="󰂲  Toggle (OFF)"
        choice=$(show_rofi "Bluetooth" "󰂱  Connect" "󰂯  Status" "$toggle_entry" "󰂲  Disconnect" "󰒓  Settings" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Connect"*)    do_bt_connect ;;
            *"Status"*)     do_bt_status ;;
            *"Toggle"*)     do_bt_toggle ;;
            *"Disconnect"*) do_bt_disconnect ;;
            *"Settings"*)   do_bt_settings; return ;;
            *"Back"*|"")    return ;;
        esac
    done
}

hier_audio_menu() {
    while true; do
        local current_sink mute_entry choice
        current_sink=$(wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep "node.description" | cut -d'"' -f2)
        [[ -z "$current_sink" ]] && current_sink="Unknown"
        wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -q MUTED \
            && mute_entry="󰖁  Toggle Mute (ON)" || mute_entry="󰕾  Toggle Mute (OFF)"
        choice=$(show_rofi "Audio ($current_sink)" \
            "󰓃  Output Device" "󰍬  Input Device" "$mute_entry" "󰍭  Mute Mic" "󰒓  Settings" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Output"*)      do_audio_output ;;
            *"Input"*)       do_audio_input ;;
            *"Toggle Mute"*) do_audio_mute_toggle ;;
            *"Mute Mic"*)    do_audio_mic_toggle ;;
            *"Settings"*)    do_audio_settings; return ;;
            *"Back"*|"")     return ;;
        esac
    done
}

hier_screenshots_menu() {
    while true; do
        local choice
        choice=$(show_rofi "Screenshots" \
            "󰹑  Area → Clipboard" "󰹑  Full → Clipboard" "󰏫  Area → Edit → Clipboard" "󰕧  Record Area" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Area → Clipboard"*) do_screenshot_area ;;
            *"Full → Clipboard"*) do_screenshot_full ;;
            *"Edit"*)             do_screenshot_edit ;;
            *"Record"*)           do_screenshot_record ;;
            *"Back"*|"")          return ;;
        esac
    done
}

hier_media_menu() {
    while true; do
        local now_playing play_entry status choice
        now_playing=$(playerctl metadata --format '{{artist}} - {{title}}' 2>/dev/null)
        [[ -z "$now_playing" ]] && now_playing="Nothing playing"
        [[ "$(playerctl status 2>/dev/null)" == "Playing" ]] && play_entry="󰏤  Pause" || play_entry="󰐎  Play"
        choice=$(show_rofi "Media" "󰎈  $now_playing" "󰒮  Previous" "$play_entry" "󰒭  Next" "  Spotify" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Previous"*)       do_media_prev ;;
            *"Play"*|*"Pause"*) do_media_play_pause ;;
            *"Next"*)           do_media_next ;;
            *"Spotify"*)        do_media_spotify ;;
            *"Back"*|"")        return ;;
        esac
    done
}

hier_themes_menu() {
    while true; do
        local choice
        local current_theme
        current_theme=$(cat ~/.config/.current-theme 2>/dev/null || echo "unknown")
        choice=$(show_rofi "Themes ($current_theme)" \
            "󰔎  Catppuccin Mocha" "󰌪  Everforest" "󰗀  Rose Pine" "󰛩  Gruvbox" \
            "󰒘  Kanagawa" "󰍂  Nord" "󰒲  Cycle" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Catppuccin"*) do_theme_catppuccin ;;
            *"Everforest"*) do_theme_everforest ;;
            *"Rose Pine"*)  do_theme_rose_pine ;;
            *"Gruvbox"*)    do_theme_gruvbox ;;
            *"Kanagawa"*)   do_theme_kanagawa ;;
            *"Nord"*)       do_theme_nord ;;
            *"Cycle"*)      do_theme_cycle ;;
            *"Back"*|"")    return ;;
        esac
    done
}

