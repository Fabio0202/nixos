}

hier_nix_menu() {
    while true; do
        local choice
        choice=$(show_rofi "Nix" "󱄅  Update" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Update"*)  do_nix_update ;;
            *"Back"*|"") return ;;
        esac
    done
}

hier_timer_menu() {
    while true; do
        local timer_status choice
        timer_status=$(timer status 2>/dev/null)
        if [[ "$timer_status" == "ringing" ]]; then
            choice=$(show_rofi "Timer (ALARM!)" "󰂛  Dismiss Alarm" "←  Back")
        elif [[ "$timer_status" == "running" ]]; then
            choice=$(show_rofi "Timer ($(timer remaining 2>/dev/null))" "󰜺  Cancel Timer" "←  Back")
        else
            choice=$(show_rofi "Timer" \
                "󰄉  Set Timer" "󰥔  5 minutes" "󰥔  10 minutes" "󰥔  15 minutes" "󰥔  30 minutes" "←  Back")
        fi
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Dismiss"*)    do_timer_dismiss ;;
            *"Cancel"*)     do_timer_cancel ;;
            *"Set Timer"*)  do_timer_set ;;
            *"5 minutes"*)  do_timer_5 ;;
            *"10 minutes"*) do_timer_10 ;;
            *"15 minutes"*) do_timer_15 ;;
            *"30 minutes"*) do_timer_30 ;;
            *"Back"*|"")    return ;;
        esac
    done
}

hier_config_menu() {
    while true; do
        local choice
        choice=$(show_rofi "Config" \
            "󰌌  Keybinds" "󰀻  Waybar" "󰍹  Monitors" \
            "󱄅  NixOS Packages" "󰘳  Shell Aliases" "󰣀  SSH Clients" "←  Back")
        [[ $? -eq 10 ]] && return
        case "$choice" in
            *"Keybinds"*)       do_edit_keybinds ;;
            *"Waybar"*)         do_edit_waybar ;;
            *"Monitors"*)       do_edit_monitors ;;
            *"NixOS Packages"*) do_edit_packages ;;
            *"Shell Aliases"*)  do_edit_aliases ;;
            *"SSH Clients"*)    do_edit_ssh_config ;;
            *"Back"*|"")        return ;;
        esac
    done
}

