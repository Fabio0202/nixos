# Misc
do_hyprsunset_toggle() {
    if pgrep -x hyprsunset > /dev/null; then
        pkill hyprsunset && notify "Hyprsunset disabled"
    else
        hyprsunset -t 4500 & notify "Hyprsunset enabled (4500K)"
    fi
}

do_color_picker() {
    local color
    color=$(hyprpicker -a)
    [[ -n "$color" ]] && notify "Copied: $color"
}

# Timer
do_timer_set() {
    local minutes
    minutes=$(rofi -dmenu -p "Timer" -theme-str 'entry { placeholder: "Minutes..."; }')
    [[ -n "$minutes" && "$minutes" =~ ^[0-9]+$ ]] && timer set "$minutes" && exit 0
}
do_timer_5()       { timer set 5;    exit 0; }
do_timer_10()      { timer set 10;   exit 0; }
do_timer_15()      { timer set 15;   exit 0; }
do_timer_30()      { timer set 30;   exit 0; }
do_timer_cancel()  { timer cancel; }
do_timer_dismiss() { timer dismiss; }

