#!/usr/bin/env bash
# Everything Menu - Flat search + frecency + hierarchical browse
#
# Frecency file: ~/.local/share/everything-menu/frecency.tsv
# Format (tab-separated): id <TAB> count <TAB> last_used <TAB> label
# To review/prune: open the file and delete any lines you don't want.
# Entries not in the file start at count 0.

FRECENCY_FILE="$HOME/.local/share/everything-menu/frecency.tsv"
ROFI_OPTS="-dmenu -i -markup-rows"

mkdir -p "$(dirname "$FRECENCY_FILE")"

# ─── UTILITIES ────────────────────────────────────────────────────────────────

notify() { notify-send -t 2000 "Everything Menu" "$1"; }
edit_config() { kitty --title "Edit: $1" -e nvim "$2" & }

show_rofi() {
    local prompt="$1"; shift
    printf '%s\n' "$@" | rofi $ROFI_OPTS -kb-cancel "" -kb-custom-1 "Escape" -p "$prompt"
}

# ─── FRECENCY ─────────────────────────────────────────────────────────────────

frecency_bump() {
    local id="$1" label="$2"
    local today count tmp
    today=$(date +%Y-%m-%d)
    tmp=$(mktemp)

    if grep -q "^${id}	" "$FRECENCY_FILE" 2>/dev/null; then
        count=$(grep -m1 "^${id}	" "$FRECENCY_FILE" | cut -f2)
        count=$((count + 1))
        grep -v "^${id}	" "$FRECENCY_FILE" > "$tmp"
    else
        count=1
        cp "$FRECENCY_FILE" "$tmp" 2>/dev/null || true
    fi
    printf '%s\t%d\t%s\t%s\n' "$id" "$count" "$today" "$label" >> "$tmp"
    mv "$tmp" "$FRECENCY_FILE"
}

# ─── ACTIONS ──────────────────────────────────────────────────────────────────
# Standalone functions — called from both flat and hierarchical menus

# System
do_shutdown() { systemctl poweroff; }
do_reboot()   { systemctl reboot; }
do_suspend()  { systemctl suspend; }
do_lock()     { hyprlock; }

# Wifi
do_wifi_connect() {
    local networks selected ssid
    networks=$(nmcli -t -f SSID,SIGNAL,SECURITY device wifi list | grep -v '^:' | sort -t: -k2 -nr | awk -F: '{
        signal=$2
        if (signal >= 75) icon="󰤨"
        else if (signal >= 50) icon="󰤥"
        else if (signal >= 25) icon="󰤢"
        else icon="󰤟"
        security=$3 ? "󰌆" : ""
        printf "%s %s %s %s\n", icon, $1, security, signal"%"
    }')
    [[ -z "$networks" ]] && { notify "No networks found"; return; }
    selected=$(echo "$networks" | rofi $ROFI_OPTS -p "Connect to Wifi")
    [[ -z "$selected" ]] && return
    ssid=$(echo "$selected" | awk '{print $2}')
    nmcli device wifi connect "$ssid" && notify "Connected to $ssid" || notify "Failed to connect"
}

do_wifi_toggle() {
    nmcli radio wifi toggle; sleep 0.5
    nmcli radio wifi | grep -q enabled && notify "Wifi enabled" || notify "Wifi disabled"
}

do_wifi_disconnect() {
    local active
    active=$(nmcli -t -f NAME,TYPE connection show --active | grep wireless | cut -d: -f1)
    [[ -n "$active" ]] && nmcli connection down "$active" && notify "Disconnected from $active" || notify "No active connection"
}

do_wifi_status() {
    local active name device ip
    active=$(nmcli -t -f NAME,DEVICE connection show --active | grep -v "lo:" | head -1)
    if [[ -n "$active" ]]; then
        name=$(echo "$active" | cut -d: -f1)
        device=$(echo "$active" | cut -d: -f2)
        ip=$(nmcli -t -f IP4.ADDRESS device show "$device" | cut -d: -f2 | head -1)
        notify "Connected: $name\nIP: $ip"
    else
        notify "Not connected"
    fi
}

do_wifi_settings() { kitty --title "Wifi Settings" -e nmtui & }

# Bluetooth
do_bt_connect() {
    local devices selected mac
    devices=$(bluetoothctl devices | awk '{mac=$2; $1=$2=""; name=substr($0,3); printf "󰂱  %s (%s)\n", name, mac}')
    [[ -z "$devices" ]] && { notify "No paired devices. Opening settings..."; kitty --title "Bluetooth" -e bluetoothctl & return; }
    selected=$(echo "$devices" | rofi $ROFI_OPTS -p "Connect Bluetooth")
    [[ -z "$selected" ]] && return
    mac=$(echo "$selected" | grep -oE '[0-9A-F:]{17}')
    bluetoothctl connect "$mac" && notify "Connected" || notify "Failed to connect"
}

do_bt_toggle() {
    if bluetoothctl show | grep -q "Powered: yes"; then
        bluetoothctl power off && notify "Bluetooth disabled"
    else
        bluetoothctl power on && notify "Bluetooth enabled"
    fi
}

do_bt_disconnect() {
    local mac
    mac=$(bluetoothctl devices Connected | awk '{print $2}' | head -1)
    [[ -n "$mac" ]] && bluetoothctl disconnect "$mac" && notify "Disconnected" || notify "No device connected"
}

do_bt_status() {
    local connected
    connected=$(bluetoothctl devices Connected | awk '{$1=$2=""; print substr($0,3)}' | head -1)
    [[ -n "$connected" ]] && notify "Connected: $connected" || notify "No device connected"
}

do_bt_settings() { kitty --title "Bluetooth" -e bluetuith & }

# Audio
do_audio_output() {
    local sinks selected desc sink_name
    sinks=$(pactl list sinks short | while read -r id name _; do
        desc=$(pactl list sinks | grep -A20 "Sink #$id" | grep "Description:" | cut -d: -f2 | xargs)
        echo "󰓃  $desc"
    done)
    [[ -z "$sinks" ]] && return
    selected=$(echo "$sinks" | rofi $ROFI_OPTS -p "Output Device")
    [[ -z "$selected" ]] && return
    desc=$(echo "$selected" | sed 's/󰓃  //')
    sink_name=$(pactl list sinks | grep -B20 "$desc" | grep "Name:" | tail -1 | cut -d: -f2 | xargs)
    [[ -n "$sink_name" ]] && pactl set-default-sink "$sink_name" && notify "Output: $desc"
}

do_audio_input() {
    local sources selected desc source_name
    sources=$(pactl list sources short | grep -v monitor | while read -r id name _; do
        desc=$(pactl list sources | grep -A20 "Source #$id" | grep "Description:" | cut -d: -f2 | xargs)
        [[ -n "$desc" ]] && echo "󰍬  $desc"
    done)
    [[ -z "$sources" ]] && return
    selected=$(echo "$sources" | rofi $ROFI_OPTS -p "Input Device")
    [[ -z "$selected" ]] && return
    desc=$(echo "$selected" | sed 's/󰍬  //')
    source_name=$(pactl list sources | grep -B20 "$desc" | grep "Name:" | tail -1 | cut -d: -f2 | xargs)
    [[ -n "$source_name" ]] && pactl set-default-source "$source_name" && notify "Input: $desc"
}

do_audio_mute_toggle() {
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED && notify "Audio muted" || notify "Audio unmuted"
}

do_audio_mic_toggle() {
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
    wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -q MUTED && notify "Microphone muted" || notify "Microphone unmuted"
}

do_audio_settings() { kitty --title "Audio" -e pulsemixer & }

# Screenshots
do_screenshot_area()   { grim -g "$(slurp)" - | wl-copy && notify "Screenshot copied"; }
do_screenshot_full()   { grim - | wl-copy && notify "Screenshot copied"; }
do_screenshot_edit()   { grim -g "$(slurp)" - | swappy -f -; }
do_screenshot_record() {
    local RECORDINGS_DIR="$HOME/Videos/Recordings" filename geometry
    mkdir -p "$RECORDINGS_DIR"
    filename="$RECORDINGS_DIR/recording-$(date +%Y%m%d-%H%M%S).mp4"
    notify "Select area, recording starts in 3s..."
    geometry=$(slurp)
    [[ -z "$geometry" ]] && return
    sleep 3
    notify "Recording... Press Super+Shift+R to stop"
    wf-recorder -g "$geometry" -f "$filename"
    if [[ -f "$filename" ]]; then
        echo -n "$filename" | wl-copy
        notify "Saved: $(basename "$filename")\n(Path copied to clipboard)"
        nautilus "$RECORDINGS_DIR" &
    fi
}

# Media
do_media_prev()       { playerctl previous; }
do_media_play_pause() { playerctl play-pause; }
do_media_next()       { playerctl next; }
do_media_spotify()    { spotify & exit 0; }

# SSH
do_ssh_connect() {
    local hosts selected host
    hosts=$(grep -E "^Host " ~/.ssh/config 2>/dev/null | awk '{print $2}' | grep -v '\*')
    [[ -z "$hosts" ]] && { notify "No SSH hosts found"; return; }
    selected=$(echo "$hosts" | awk '{print "󰣀  " $0}' | rofi $ROFI_OPTS -p "SSH")
    [[ -z "$selected" ]] && return
    host=$(echo "$selected" | sed 's/󰣀  //')
    kitty --title "SSH: $host" -e ssh "$host" &
}

